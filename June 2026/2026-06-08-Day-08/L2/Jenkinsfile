pipeline {
    agent any 
    stages {
        stage('Build Docker Image') {
            steps {
                script {
                    docker.build('pathnex-app')
                }
            }

        }
        stage('Push Docker Image'){
            steps {
                script {
                    docker.withRegistry('https://docker.io', 'docker-credentials'){
                    docker.image('pathnex-app').push('latest')}
                }
            }
        }
    }
}